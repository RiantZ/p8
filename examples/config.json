{
    //Name of the logging session, if skipped - name of the hosting process is used instead
    "Name" : "MySession",

    //internal library logging, next options available
    // * stdout - to console
    // * filepath - to text file, for example "./mylogfile.txt"
    // * null - no logging
    "logging": "null",

    "Modules":
    [
        //Verbosity values: Trace, Debug, Info, Warning, Error, Critical
        {"_": "Trace"}, //default verbosity for all traces with no module
        {"MyModule1":"Debug"},
        {"MyModule2":"Debug"}
    ],

    //Available sinks:
    // * Baigal - Deliver to Baigal over network
    // * FileBin - Deliver to binary file
    // * Auto - Deliver to Baigal, if server is OFF -> to bin file
    // * Null - drop
    "sink" : "Baigal",
    "Baigal":
    {
        //server address, IPV4 address : XXX.XXX.XXX.XXX, IPV6 address : ::1, etc. NetBios Name
        "RemoteIp": "::1",
        "RemotePort": "1008",
        //size of the data packet, Min: 512, Max: 65535, default = 0 (auto: most optimum)
        "PacketSize": "0",
        //server timeout in milliseconds
        "TimeoutMs": "2000"
    },
    "FileBin":
    {
        "OutDir":"./mySubDir/myLogDir",
        //Rolling type:
        //* Xmb     - rolling every X megabytes, for example 10MB
        //* Xhr     - rolling every X hours, for example 24HR, max = 1000HR
        //* HH:MMtm - rolling by time (00:00 -> 23:59), for example:
        //   * rolling at 12:00 -> 12:00tm
        //   * rolling at 12:00 and 00:00 -> 00:00,12:00tm
        // * off
        "Roll":"off",

        //Maximum P8 logs files in destination folder "OutDir".
        //In case if count of files is larger than specified value - oldest files will be removed
        //default : 0 (off)
        //max     : 4096
        "MaxFiles":"0",

        //Value: define maximum P8 logs files cumulative size in MB at destination folder "OutDir".
        //In case if size of files is larger than specified value - oldest files will be removed.
        //default : 0 (off)
        //max     : 4294967296
        "MaxSizeMB":"0"
    }
}